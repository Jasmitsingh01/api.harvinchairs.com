{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://api.harvinchairs.com",
    "APP_KEY": "@app_key",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "@db_host",
    "DB_PORT": "3306",
    "DB_DATABASE": "@db_database",
    "DB_USERNAME": "@db_username",
    "DB_PASSWORD": "@db_password",
    "CACHE_DRIVER": "file",
    "SESSION_DRIVER": "file",
    "QUEUE_DRIVER": "sync",
    "MAIL_DRIVER": "smtp",
    "MAIL_HOST": "@mail_host",
    "MAIL_PORT": "587",
    "MAIL_USERNAME": "@mail_username",
    "MAIL_PASSWORD": "@mail_password",
    "MAIL_ENCRYPTION": "tls",
    "MAIL_FROM_ADDRESS": "@mail_from_address",
    "MAIL_FROM_NAME": "Harvin Chairs",
    "FILESYSTEM_DISK": "local",
    "BROADCAST_DRIVER": "log",
    "LOG_CHANNEL": "stack",
    "LOG_LEVEL": "error"
  }
} 